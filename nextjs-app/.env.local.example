# Copy this file to .env.local and fill in your Supabase project values.
# NEVER commit .env.local to version control.

# ── Public (safe to expose to the browser) ──────────────────────────────────
# NEXT_PUBLIC_ prefix means Next.js will bundle these into the client bundle.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Server-only (NEVER add NEXT_PUBLIC_ prefix here) ────────────────────────
# Used only in Server Components, API Routes, and middleware.
# Bypasses Row Level Security — keep this secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
